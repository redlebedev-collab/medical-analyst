# Скопируйте этот файл в .env и заполните свои значения:
#   cp .env.example .env

# API-ключ Anthropic (обязательно)
# Получить: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Активный пациент (опционально, по умолчанию "default")
# Переключение между профилями:
#   Windows: set MEDIC_PATIENT=member_a
#   Linux/Mac: export MEDIC_PATIENT=member_a
MEDIC_PATIENT=default

# Модель Claude (опционально)
# Варианты: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001
MEDIC_MODEL=claude-opus-4-6
